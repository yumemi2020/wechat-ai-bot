# 本地大語言模型 API（OpenAI 相容介面，如 LM Studio / Ollama / vLLM）
LOCAL_API_BASE=http://127.0.0.1:1234/v1
LOCAL_API_KEY=your-api-key-or-lm-studio
LOCAL_MODEL_NAME=your-model-name

# WeChatPadProMAX 服務位址
PADPRO_URL=http://127.0.0.1:1238

# 授權碼（authcode）
PADPRO_AUTH_KEY=your-padpro-auth-key

# 本帳號微信 ID
PADPRO_WXID=your-wechat-wxid

# Webhook 對外 URL（掃碼登入成功後自動註冊至 PadPro）
PADPRO_WEBHOOK_PUBLIC_URL=http://127.0.0.1:9950/webhook

# MySQL 非同步連線（SQLAlchemy + asyncmy）
# Docker Compose 預設主機名為 db
DATABASE_URL=mysql+asyncmy://root:changeme@db:3306/wechat_ai
MYSQL_ROOT_PASSWORD=changeme

# 選填：Webhook HMAC 簽名密鑰（需與 PadPro 設定一致）
# PADPRO_WEBHOOK_SECRET=
# 選填：Mac 掃碼登入顯示的裝置名稱
# PADPRO_LOGIN_DEVICE_NAME=MacBook Pro

# 選填：連線池設定（預設 pre_ping + 30 分鐘回收）
# DB_POOL_RECYCLE=1800
# DB_POOL_TIMEOUT=30
# 選填：每位好友保留的對話輪數（預設 10）
# MAX_HISTORY_TURNS=10

# PadPro 強制同步輪詢（預設關閉；頻繁呼叫可能導致微信斷線）
# SYNC_POLL_ENABLED=false
# SYNC_POLL_INTERVAL=5
# SYNC_REQUEST_TIMEOUT=10
